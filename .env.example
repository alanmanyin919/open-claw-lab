TELEGRAM_BOT_TOKEN=

# Container build configuration
# Use a Debian or Ubuntu base image. Examples:
# OPENCLAW_BASE_IMAGE=debian:bookworm-slim
# OPENCLAW_BASE_IMAGE=debian:bullseye-slim
# OPENCLAW_BASE_IMAGE=ubuntu:24.04
OPENCLAW_BASE_IMAGE=debian:bookworm-slim
OPENCLAW_NODE_MAJOR=22
OPENCLAW_VERSION=latest

# OpenClaw agent model configuration (MiniMax only)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_MODEL=MiniMax-M2.5

# VNC desktop configuration
# Leave empty to use the insecure fallback password "change-me"
VNC_PASSWORD=
VNC_PORT=5901
SCREEN_GEOMETRY=1440x900x24
